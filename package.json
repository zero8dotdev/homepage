{
	"name": "zero8-sveltekit",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"deploy": "pnpm build && wrangler deploy"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.58.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"mdsvex": "^0.12.7",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.6",
		"typescript": "^5.9.3",
		"vite": "^7.3.2",
		"wrangler": "^4.75.0"
	},
	"dependencies": {
		"posthog-js": "^1.372.3",
		"zod": "^4.3.6"
	},
	"pnpm": {
		"overrides": {
			"protobufjs": ">=7.5.5",
			"dompurify": ">=3.4.0",
			"postcss": ">=8.5.10",
			"cookie": ">=0.7.0",
			"picomatch": ">=4.0.4"
		}
	}
}
